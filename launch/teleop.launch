<launch>
  <!-- ============================================================
       teleop.launch — Control-only pipeline for Fetch HRI experiments

       Camera is intentionally ABSENT from this file.
       Run the camera system on a separate machine with its own delay.

       Args:
         input_device    joystick | keyboard   (default: joystick)
         delay_time      One-way delay in seconds (default: 0.0)
         control_scheme  arcade | tank          (default: arcade)

       CONTROL SCHEMES
       ---------------
       arcade  Right Stick Vertical   (Axis 4) = Forward / Backward
               Left  Stick Horizontal (Axis 3) = Turn left / right

       tank    Right Stick Vertical   (Axis 4) = Forward / Backward
               Right Stick Horizontal (Axis 3) = Turn left / right
               (single stick controls all motion)

       DEADMAN
       -------
       LB = Button 4 must be held for any motion in both modes.
       ============================================================ -->

  <arg name="input_device"   default="joystick" />
  <arg name="delay_time"     default="0.0" />
  <arg name="control_scheme" default="arcade" />

  <!-- ============================================================
       INPUT SOURCE
       ============================================================ -->

  <!-- Option A: Keyboard (teleop_twist_keyboard) -->
  <group if="$(eval arg('input_device') == 'keyboard')">
    <node pkg="teleop_twist_keyboard" type="teleop_twist_keyboard.py"
          name="teleop_keyboard" output="screen">
      <remap from="cmd_vel" to="cmd_vel_raw" />
    </node>
  </group>

  <!-- Option B: Joystick (ONN / Xbox controller) -->
  <group if="$(eval arg('input_device') == 'joystick')">

    <!-- joy driver — remapped to /my_joy to avoid conflict with Fetch internal driver -->
    <node pkg="joy" type="joy_node" name="joy_driver">
      <param name="dev"             value="/dev/input/js0" />
      <param name="deadzone"        value="0.1" />
      <param name="autorepeat_rate" value="20" />
      <remap from="joy" to="my_joy" />
    </node>

    <!-- Joystick translator -->
    <node pkg="fetch_control" type="joystick_translator.py"
          name="joystick_translator" output="screen">

      <!-- Axis layout (ONN/Xbox controller)
           Axis 3 = Left  Stick Horizontal  (arcade: turn)
           Axis 4 = Right Stick Vertical    (both modes: fwd/back)
           Axis 3 = Right Stick Horizontal  (tank: turn — same index as left horiz
                                             because on this controller layout they
                                             share axis 3; confirm with jstest if needed) -->
      <param name="axis_fwd_back"    value="4" />   <!-- Right Stick Vertical -->
      <param name="axis_turn_arcade" value="3" />   <!-- Left  Stick Horizontal -->
      <param name="axis_turn_tank"   value="3" />   <!-- Right Stick Horizontal -->
      <param name="deadman_button"   value="4" />   <!-- LB button -->
      <param name="scale_linear"     value="0.5" />
      <param name="scale_angular"    value="1.0" />
      <param name="control_scheme"   value="$(arg control_scheme)" />
      <remap from="joy" to="my_joy" />
    </node>

  </group>

  <!-- ============================================================
       DELAY NODE
       ============================================================ -->
  <node pkg="fetch_control" type="cmd_delay.py"
        name="cmd_delay_node" output="screen">
    <param name="delay" value="$(arg delay_time)" />
  </node>

  <!-- ============================================================
       ADMITTANCE CONTROLLER
       ============================================================ -->
  <node pkg="fetch_control" type="admittance_controller.py"
        name="admittance_node" output="screen">
    <param name="virtual_mass"    value="0.5" />
    <param name="virtual_damping" value="1.0" />
    <param name="max_linear_vel"  value="1.0" />
    <param name="max_angular_vel" value="1.5" />
  </node>

  <!-- ============================================================
       SAFETY CONTROLLER
       Real-time LIDAR guard — NOT subject to delay.
       ============================================================ -->
  <node pkg="fetch_control" type="safety_controller_twist.py"
        name="safety_twist" output="screen" />

</launch>
